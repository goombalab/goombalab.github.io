<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zero-Shot Benchmarks Table</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        body {
            background-color: transparent;
            color: #0f172a;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            overflow-y: hidden;
        }

        .table-container {
            background: #ffffff;
            border-radius: 0.75rem;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            width: 100%;
             /* Kept slightly constrained as it has fewer columns than the previous table */
        }

        .table-scroll-wrapper {
            overflow-x: auto;
            overflow-y: auto;
            max-height: 480px;
            width: 100%;
            scrollbar-width: thin;
            scrollbar-color: #cbd5e1 #f8fafc;
        }

        .table-scroll-wrapper::-webkit-scrollbar {
            height: 8px;
        }
        .table-scroll-wrapper::-webkit-scrollbar-track {
            background: #f8fafc;
        }
        .table-scroll-wrapper::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 4px;
        }

        table {
            border-collapse: separate;
            border-spacing: 0;
            width: 100%;
            min-width: 800px;
            text-align: center;
        }

        thead {
            position: sticky;
            top: 0;
            z-index: 25;
            background-color: #f8fafc;
        }

        th {
            background-color: inherit;
            color: #334155;
            font-weight: 600;
            font-size: clamp(0.6rem, 1.4vw, 0.85rem);
            padding: 0.3rem 0.4rem;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
        }

        td {
            padding: 0.3rem 0.4rem;
            font-size: clamp(0.65rem, 1.5vw, 0.9rem);
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
            white-space: nowrap;
        }

        /* Sticky first column */
        thead tr:first-child th:first-child, td:first-child {
            position: sticky;
            left: 0;
            background-color: inherit;
            z-index: 20;
            text-align: left;
            padding-left: 1rem;
            border-right: 1px solid #e2e8f0;
        }
        thead tr:first-child th:first-child {
            top: 0;
            z-index: 30;
        }

        /* Removed old sticky rules */

        tr { background-color: #ffffff; }
        
        /* Column background colors mapping to orange!10 */
        .col-avg { background-color: #fff7ed; } /* orange-50 */
        
        /* The thick vertical dividers mapping to LaTeX | */
        .border-r-thick { border-right: 2px solid #cbd5e1 !important; }

        /* Row background color mapping */
        .row-ours { 
            background-color: #eaf2fe; 
        }
        /* Let the blue bleed through the orange column on the "Ours" row */
        .row-ours .col-avg {
            background-color: transparent; 
        }

        /* Underline styling matching LaTeX \underline */
        .ul { text-decoration: underline; text-underline-offset: 2px; text-decoration-color: #94a3b8; }

        /* Caption Styling */
        .caption-box {
            
            margin-bottom: 1.5rem;
            color: #475569; /* slate-600 */
            font-size: 0.875rem;
            line-height: 1.6;
            text-align: left;
        }
    </style>
</head>
<body>

    <div class="w-full xl:max-w-[1000px]">
        
        

        
        <!-- Buttons -->
        <div class="flex justify-center mb-4">
            <div class="inline-flex rounded-md shadow-sm" role="group">
                <button type="button" id="btn-400m" class="px-4 py-2 text-sm font-medium text-blue-700 bg-white border border-gray-200 rounded-l-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 active-btn" style="background-color: #ebf5ff;">
                    ~400M
                </button>
                <button type="button" id="btn-800m" class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-r-md hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 focus:text-blue-700">
                    ~800M
                </button>
            </div>
        </div>

        <!-- Table Container -->
        <div class="table-container">
            <div class="table-scroll-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th rowspan="2" class="border-r-thick">Model</th>
                            <th rowspan="2" class="border-r-thick"># Params<br><span class="font-normal text-slate-500">(M)</span></th>
                            <th>LMB.</th>
                            <th>LMB.</th>
                            <th>PIQA</th>
                            <th>Hella.</th>
                            <th>Wino.</th>
                            <th>ARC-e</th>
                            <th class="border-r-thick">ARC-c</th>
                            <th class="col-avg">Avg.</th>
                        </tr>
                        <tr>
                            <th>ppl\(\downarrow\)</th>
                            <th>acc\(\uparrow\)</th>
                            <th>acc\(\uparrow\)</th>
                            <th>acc\(\uparrow\)</th>
                            <th>acc\(\uparrow\)</th>
                            <th>acc\(\uparrow\)</th>
                            <th class="border-r-thick">acc\(\uparrow\)</th>
                            <th class="col-avg">acc\(\uparrow\)</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-400m">
                        <!-- BLOCK 1: ~400M -->
                        
                        <tr>
                            <td class="font-bold italic text-slate-700" colspan="10">Transformer</td>
                        </tr>
                        <tr>
                            <td class="italic pl-6">w. RoPE</td>
                            <td class="border-r-thick">340</td>
                            <td>42.0</td>
                            <td>31.0</td>
                            <td>64.4</td>
                            <td>30.2</td>
                            <td>51.0</td>
                            <td>44.3</td>
                            <td class="border-r-thick">18.7</td>
                            <td class="col-avg">39.9</td>
                        </tr>
                        <tr>
                            <td class="italic pl-6">w. Gate (FoX)</td>
                            <td class="border-r-thick">376</td>
                            <td>48.1</td>
                            <td>30.6</td>
                            <td>64.9</td>
                            <td>30.7</td>
                            <td>51.1</td>
                            <td>44.7</td>
                            <td class="border-r-thick">18.9</td>
                            <td class="col-avg">40.1</td>
                        </tr>
                        <tr>
                            <td class="font-bold italic text-slate-700" colspan="10">SSM</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GLA</td>
                            <td class="border-r-thick">400</td>
                            <td>42.1</td>
                            <td>30.7</td>
                            <td>64.4</td>
                            <td>30.1</td>
                            <td>52.7</td>
                            <td>43.8</td>
                            <td class="border-r-thick">19.6</td>
                            <td class="col-avg">40.2</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GSA</td>
                            <td class="border-r-thick">399</td>
                            <td>44.1</td>
                            <td>30.3</td>
                            <td>64.9</td>
                            <td>30.7</td>
                            <td>51.5</td>
                            <td>45.6</td>
                            <td class="border-r-thick">20.5</td>
                            <td class="col-avg ul">40.5</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GDN</td>
                            <td class="border-r-thick">475</td>
                            <td>40.1</td>
                            <td>31.6</td>
                            <td>65.6</td>
                            <td>31.4</td>
                            <td>50.2</td>
                            <td>45.7</td>
                            <td class="border-r-thick">19.3</td>
                            <td class="col-avg font-bold">40.6</td>
                        </tr>
                        <tr>
                            <td class="pl-6">Mamba-2</td>
                            <td class="border-r-thick">382</td>
                            <td>43.0</td>
                            <td>29.9</td>
                            <td>65.0</td>
                            <td>31.5</td>
                            <td>51.2</td>
                            <td>47.5</td>
                            <td class="border-r-thick">20.5</td>
                            <td class="col-avg">40.1</td>
                        </tr>
                        <tr>
                            <td class="pl-6">SWA</td>
                            <td class="border-r-thick">374</td>
                            <td>40.7</td>
                            <td>30.5</td>
                            <td>64.5</td>
                            <td>30.4</td>
                            <td>51.6</td>
                            <td>44.9</td>
                            <td class="border-r-thick">18.6</td>
                            <td class="col-avg">40.0</td>
                        </tr>
                        <tr class="row-ours">
                            <td class="pl-6 text-blue-700 font-bold">Ours</td>
                            <td class="border-r-thick">424</td>
                            <td>41.0</td>
                            <td>32.7</td>
                            <td>64.1</td>
                            <td>30.3</td>
                            <td>51.7</td>
                            <td>43.9</td>
                            <td class="border-r-thick">18.4</td>
                            <td class="col-avg">40.2</td>
                        </tr>
                    </tbody>
                    <tbody id="tbody-800m" class="hidden">
                        <!-- BLOCK 2: ~800M -->
                        
                        <tr>
                            <td class="font-bold italic text-slate-700" colspan="10">Transformer</td>
                        </tr>
                        <tr>
                            <td class="italic pl-6">w. RoPE</td>
                            <td class="border-r-thick">693</td>
                            <td>18.6</td>
                            <td>41.4</td>
                            <td>66.3</td>
                            <td>34.3</td>
                            <td>52.2</td>
                            <td>49.9</td>
                            <td class="border-r-thick">21.9</td>
                            <td class="col-avg ul">44.5</td>
                        </tr>
                        <tr>
                            <td class="italic pl-6">w. Gate (FoX)</td>
                            <td class="border-r-thick">694</td>
                            <td>25.3</td>
                            <td>38.2</td>
                            <td>67.8</td>
                            <td>34.4</td>
                            <td>51.7</td>
                            <td>49.9</td>
                            <td class="border-r-thick">21.5</td>
                            <td class="col-avg">44.1</td>
                        </tr>
                        <tr>
                            <td class="font-bold italic text-slate-700" colspan="10">SSM</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GLA</td>
                            <td class="border-r-thick">892</td>
                            <td>23.6</td>
                            <td>38.25</td>
                            <td>66.97</td>
                            <td>33.37</td>
                            <td>52.41</td>
                            <td>48.53</td>
                            <td class="border-r-thick">21.25</td>
                            <td class="col-avg">43.46</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GSA</td>
                            <td class="border-r-thick">750</td>
                            <td>27.4</td>
                            <td>34.68</td>
                            <td>66.32</td>
                            <td>32.10</td>
                            <td>51.62</td>
                            <td>46.63</td>
                            <td class="border-r-thick">19.62</td>
                            <td class="col-avg">41.83</td>
                        </tr>
                        <tr>
                            <td class="pl-6">GDN</td>
                            <td class="border-r-thick">892</td>
                            <td>21.3</td>
                            <td>39.4</td>
                            <td>68.1</td>
                            <td>35.2</td>
                            <td>53.0</td>
                            <td>52.5</td>
                            <td class="border-r-thick">22.1</td>
                            <td class="col-avg font-bold">45.1</td>
                        </tr>
                        <tr>
                            <td class="pl-6">Mamba-2</td>
                            <td class="border-r-thick">712</td>
                            <td>24.6</td>
                            <td>36.0</td>
                            <td>68.1</td>
                            <td>35.4</td>
                            <td>52.6</td>
                            <td>52.3</td>
                            <td class="border-r-thick">22.3</td>
                            <td class="col-avg">44.5</td>
                        </tr>
                        <tr>
                            <td class="pl-6">SWA</td>
                            <td class="border-r-thick">693</td>
                            <td>20.8</td>
                            <td>38.8</td>
                            <td>67.9</td>
                            <td>34.2</td>
                            <td>52.8</td>
                            <td>49.3</td>
                            <td class="border-r-thick">21.2</td>
                            <td class="col-avg">44.0</td>
                        </tr>
                        <tr class="row-ours">
                            <td class="pl-6 text-blue-700 font-bold">Ours</td>
                            <td class="border-r-thick">792</td>
                            <td>26.0</td>
                            <td>38.2</td>
                            <td>67.0</td>
                            <td>33.2</td>
                            <td>50.9</td>
                            <td>49.2</td>
                            <td class="border-r-thick">21.0</td>
                            <td class="col-avg">43.3</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>


    <script>
        const btn400 = document.getElementById('btn-400m');
        const btn800 = document.getElementById('btn-800m');
        const tbody400 = document.getElementById('tbody-400m');
        const tbody800 = document.getElementById('tbody-800m');

        btn400.addEventListener('click', () => {
            tbody400.classList.remove('hidden');
            tbody800.classList.add('hidden');
            btn400.classList.add('text-blue-700');
            btn400.classList.remove('text-gray-900');
            btn400.style.backgroundColor = '#ebf5ff';
            btn800.classList.remove('text-blue-700');
            btn800.classList.add('text-gray-900');
            btn800.style.backgroundColor = 'white';
        });

        btn800.addEventListener('click', () => {
            tbody800.classList.remove('hidden');
            tbody400.classList.add('hidden');
            btn800.classList.add('text-blue-700');
            btn800.classList.remove('text-gray-900');
            btn800.style.backgroundColor = '#ebf5ff';
            btn400.classList.remove('text-blue-700');
            btn400.classList.add('text-gray-900');
            btn400.style.backgroundColor = 'white';
        });
    </script>
</body>

</html>
