                            <td class="border-r-thick font-bold">39.9</td>
                            <td>99.8</td><td class="font-bold">100</td><td>99.8</td><td>99.2</td><td class="font-bold">98.2</td><td class="border-r-thick font-bold">91.0</td>
                            <td class="font-bold">100</td><td class="font-bold">99.4</td><td class="font-bold">90.8</td><td class="font-bold">35.2</td><td>6.8</td><td class="border-r-thick">3.4</td>
                            <td class="font-bold">90.4</td><td>5.2</td><td>0.6</td><td>0.0</td><td>0.0</td><td>0.0</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        const btn400 = document.getElementById('btn-400m');
        const btn800 = document.getElementById('btn-800m');
        const tbody400 = document.getElementById('tbody-400m');
        const tbody800 = document.getElementById('tbody-800m');
        
        // Grab headers
        const cols1 = document.querySelectorAll('.len-1');
        const cols2 = document.querySelectorAll('.len-2');
        const cols3 = document.querySelectorAll('.len-3');
        const cols4 = document.querySelectorAll('.len-4');
        const cols5 = document.querySelectorAll('.len-5');
        const cols6 = document.querySelectorAll('.len-6');

        btn400.addEventListener('click', () => {
            tbody400.classList.remove('hidden');
            tbody800.classList.add('hidden');
            btn400.classList.add('text-blue-700');
            btn400.classList.remove('text-gray-900');
            btn400.style.backgroundColor = '#ebf5ff';
            btn800.classList.remove('text-blue-700');
            btn800.classList.add('text-gray-900');
            btn800.style.backgroundColor = 'white';
            
            cols1.forEach(el => el.textContent = '1K');
            cols2.forEach(el => el.textContent = '2K');
            cols3.forEach(el => el.textContent = '4K');
            cols4.forEach(el => el.textContent = '8K');
            cols5.forEach(el => el.textContent = '16K');
            cols6.forEach(el => el.textContent = '32K');
        });

        btn800.addEventListener('click', () => {
            tbody800.classList.remove('hidden');
            tbody400.classList.add('hidden');
            btn800.classList.add('text-blue-700');
            btn800.classList.remove('text-gray-900');
            btn800.style.backgroundColor = '#ebf5ff';
            btn400.classList.remove('text-blue-700');
            btn400.classList.add('text-gray-900');
            btn400.style.backgroundColor = 'white';
            
            cols1.forEach(el => el.textContent = '2K');
            cols2.forEach(el => el.textContent = '4K');
            cols3.forEach(el => el.textContent = '8K');
            cols4.forEach(el => el.textContent = '16K');
            cols5.forEach(el => el.textContent = '32K');
            cols6.forEach(el => el.textContent = '64K');
        });
    </script>
</body>
</html>
