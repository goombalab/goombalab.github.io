<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>In-context Recall Benchmarks Table</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        body {
            background-color: transparent;
            color: #0f172a; /* Slate 900 */
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            
        }

        .table-container {
            background: #ffffff;
            border-radius: 0.75rem;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            width: 100%;
        }

        .table-scroll-wrapper {
            overflow-x: auto;
            overflow-y: auto;
            max-height: 480px;
            width: 100%;
            /* Custom scrollbar for better UX on wide tables */
            scrollbar-width: thin;
            scrollbar-color: #cbd5e1 #f8fafc;
        }

        .table-scroll-wrapper::-webkit-scrollbar {
            height: 8px;
        }
        .table-scroll-wrapper::-webkit-scrollbar-track {
            background: #f8fafc;
        }
        .table-scroll-wrapper::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 4px;
        }

        table {
            border-collapse: separate;
            border-spacing: 0;
            width: 100%;
            min-width: 1200px;
            text-align: center;
        }

        thead {
            position: sticky;
            top: 0;
            z-index: 25;
            background-color: #f8fafc;
        }

        th {
            background-color: inherit;
            color: #334155;
            font-weight: 600;
            font-size: clamp(0.55rem, 1.2vw, 0.8rem);
            padding: 0.25rem 0.2rem;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
        }

        td {
            padding: 0.25rem 0.25rem;
            font-size: clamp(0.6rem, 1.3vw, 0.85rem);
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
            white-space: nowrap;
        }

        /* Sticky first column */
        thead tr:first-child th:first-child, td:first-child {
            position: sticky;
            left: 0;
            background-color: inherit;
            z-index: 20;
            text-align: left;
            padding-left: 1rem;
            border-right: 1px solid #e2e8f0;
        }
        thead tr:first-child th:first-child {
            top: 0; /* Ensures it stays sticky vertically as well */
            z-index: 30; /* Header needs to sit above standard sticky column */
        }

        /* Default row background handling for sticky cols to cover scrolling content */
        tr { background-color: #ffffff; }
        
        /* Column background colors mapping to gray!10 */
        .col-recall { background-color: #f8fafc; }
        
        /* The thick vertical dividers mapping to LaTeX | */
        .border-r-thick { border-right: 2px solid #cbd5e1 !important; }

        /* Row background color mapping */
        .row-phoenix { 
            background-color: #eaf2fe; /* solid color so sticky cols cover content */
        }
        .row-phoenix .col-recall {
            background-color: transparent; /* Let the blue bleed through */
        }

        /* Underline styling matching LaTeX \underline */
        .ul { text-decoration: underline; text-underline-offset: 2px; text-decoration-color: #94a3b8; }

        /* Caption Styling */
        .caption-box {
            max-width: 100%;
            margin-bottom: 1.5rem;
            color: #475569; /* slate-600 */
            font-size: 0.875rem;
            line-height: 1.6;
            text-align: left;
        }

        .highlight-blue { color: #2563eb; font-weight: 600; } /* blue-600 */
    </style>
</head>
<body>

    <div class="w-full xl:max-w-[1400px]">
        

        <!-- Buttons -->
        <div class="flex justify-center mb-4">
            <div class="inline-flex rounded-md shadow-sm" role="group">
                <button type="button" id="btn-400m" class="px-4 py-2 text-sm font-medium text-blue-700 bg-white border border-gray-200 rounded-l-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 focus:text-blue-700 active-btn" style="background-color: #ebf5ff;">
                    ~400M
                </button>
                <button type="button" id="btn-800m" class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-r-md hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 focus:text-blue-700">
                    ~800M
                </button>
            </div>
        </div>

        <!-- Table Container -->
        <div class="table-container">
            <div class="table-scroll-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th rowspan="2" class="border-r-thick">Model</th>
                            <th rowspan="2"># Params<br><span class="font-normal text-slate-500">(M)</span></th>
                            <th rowspan="2" class="border-r-thick">(Rec / Conv)<br><span class="font-normal text-slate-500">Mem. (M elts)</span></th>
                            <th colspan="3" class="col-recall border-r-thick">Recall tasks</th>
                            <th colspan="6" class="border-r-thick">NIAH-1</th>
                            <th colspan="6" class="border-r-thick">NIAH-2</th>
                            <th colspan="6">NIAH-3</th>
                        </tr>
                        <tr>
                            <!-- Recall Tasks -->
                            <th class="col-recall">SWDE</th>
                            <th class="col-recall">FDA</th>
                            <th class="col-recall border-r-thick">SQuAD</th>
                            <!-- NIAH-1 -->
                            <th><span class="len-1">1K</span></th><th><span class="len-2">2K</span></th><th><span class="len-3">4K</span></th><th><span class="len-4">8K</span></th><th><span class="len-5">16K</span></th><th class="border-r-thick"><span class="len-6">32K</span></th>
                            <!-- NIAH-2 -->
                            <th><span class="len-1">1K</span></th><th><span class="len-2">2K</span></th><th><span class="len-3">4K</span></th><th><span class="len-4">8K</span></th><th><span class="len-5">16K</span></th><th class="border-r-thick"><span class="len-6">32K</span></th>
                            <!-- NIAH-3 -->
                            <th><span class="len-1">1K</span></th><th><span class="len-2">2K</span></th><th><span class="len-3">4K</span></th><th><span class="len-4">8K</span></th><th><span class="len-5">16K</span></th><th><span class="len-6">32K</span></th>
                        </tr>
                    </thead>
